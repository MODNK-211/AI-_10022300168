# ─────────────────────────────────────────────────────────────────────────────
# The Acity Oracle Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git (it is in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# Groq API key (preferred by llm_client.py if present).
# Create at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# Optional: Groq chat model id.
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# Optional fallback: Hugging Face token used by Inference Providers (router).
# Create at: https://huggingface.co/settings/tokens
# Fine-grained tokens may need permission: "Make calls to Inference Providers".
HF_TOKEN=hf_your_token_here

# Optional: comma-separated router model ids (tried in order). Example:
# HF_CHAT_MODELS=mistralai/Mistral-7B-Instruct-v0.3:fastest,HuggingFaceH4/zephyr-7b-beta:fastest
