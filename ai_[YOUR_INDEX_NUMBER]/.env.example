# ─────────────────────────────────────────────────────────────────────────────
# AcityBot Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git (it is in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# HuggingFace Inference API token (read-only scope is sufficient)
# Obtain at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here
